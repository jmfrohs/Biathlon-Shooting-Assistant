{
  "name": "voice-command-biathlon-target",
  "version": "2.0.0",
  "description": "Biathlon Schießstand Helfer mit Sprachsteuerung",
  "main": "src/index.html",
  "scripts": {
    "dev": "node scripts/simple-server.js",
    "start": "node scripts/simple-server.js",
    "test": "node scripts/test-runner.js all",
    "tests": "node scripts/test-runner.js src",
    "tests-old": "node scripts/test-runner.js old",
    "test:watch": "echo 'Watch mode: use npm run check:src instead'",
    "test:coverage": "node scripts/test-runner.js all --coverage",
    "test:report": "node scripts/test-report.js",
    "test:errors": "node scripts/quick-errors.js",
    "test:errors:detailed": "node scripts/error-report.js",
    "check": "node scripts/all-errors.js",
    "check:src": "node scripts/code-analysis.js",
    "format": "prettier --write \"{src,src-old}/**/*.{js,html,css}\" \"{tests-src,tests-src-old,scripts}/**/*.js\"",
    "format:licenses": "node scripts/format-with-licenses.js",
    "pre-commit": "npm run format && npm run format:licenses && npm run check:src",
    "server:start": "cd server && npm start",
    "server:stop": "cd server && npm run stop",
    "server:restart": "cd server && npm run restart",
    "server:pm2:start": "pm2 start server/index.js --name biathlon-server",
    "server:pm2:stop": "pm2 stop biathlon-server",
    "server:pm2:restart": "pm2 restart biathlon-server",
    "server:pm2:logs": "pm2 logs biathlon-server",
    "server:pm2:save": "pm2 save && pm2 startup",
    "install:all": "npm install && cd server && npm install",
    "setup:linux": "bash scripts/setup-linux.sh"
  },
  "keywords": [
    "biathlon",
    "shooting",
    "voice-command",
    "web-app"
  ],
  "author": "jmfrohs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jmfrohs/voice-command-biathlon-target"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^30.2.0",
    "prettier": "^3.0.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0"
  }
}
