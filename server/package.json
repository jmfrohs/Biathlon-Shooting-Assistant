{
  "name": "biathlon-shooting-assistant-server",
  "version": "1.0.0",
  "description": "Backend server for Biathlon Shooting Assistant",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "stop": "taskkill /F /IM node.exe 2>nul || echo No server running",
    "restart": "npm run stop && npm start"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.7.0",
    "chalk": "^4.1.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.10.1",
    "socket.io": "^4.8.3"
  }
}
