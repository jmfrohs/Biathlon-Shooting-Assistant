# Biathlon Shooting Assistant — Server Konfiguration
# Kopiere diese Datei zu server/.env und fülle die Werte aus.

# ──────────────────────────────────────────────
# Server Basis-Einstellungen
# ──────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ──────────────────────────────────────────────
# JWT Security (WICHTIG: Ändern Sie die SECRET!)
# ──────────────────────────────────────────────
# Generieren Sie einen zufälligen Secret mit mindestens 64 Zeichen:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=dein-langer-zufaelliger-geheimer-schluessel-mindestens-64-zeichen

JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ──────────────────────────────────────────────
# CORS Konfiguration (Sicherheit)
# ──────────────────────────────────────────────
# Erlaubte Origins durch Kommas getrennt
# Beispiele: http://localhost:3001,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# ──────────────────────────────────────────────
# Rate Limiting (Brute-Force Protection)
# ──────────────────────────────────────────────
# Fenster in Millisekunden (900000 = 15 Minuten)
RATE_LIMIT_WINDOW_MS=900000
# Maximale Anfragen pro Fenster
RATE_LIMIT_MAX_REQUESTS=5

# ──────────────────────────────────────────────
# Session Management
# ──────────────────────────────────────────────
# Maximale gleichzeitig aktive Sessions pro Benutzer
MAX_ACTIVE_SESSIONS=3

# ──────────────────────────────────────────────
# Datenbank Sicherheit
# ──────────────────────────────────────────────
DB_PATH=./db/biathlon.db
DB_BACKUP_PATH=./db/backups

# ──────────────────────────────────────────────
# CSRF Protection
# ──────────────────────────────────────────────
ENABLE_CSRF=true

# ──────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────
LOG_LEVEL=info

# ──────────────────────────────────────────────
# SMTP Email-Konfiguration (für Auto-Versand)
# ──────────────────────────────────────────────
# Beispiel für Gmail:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=deine@gmail.com
#   SMTP_PASS=dein-app-passwort   ← Google App Password (nicht dein Gmail-Passwort)
#
# Beispiel für Outlook/Hotmail:
#   SMTP_HOST=smtp-mail.outlook.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=deine@outlook.com
#   SMTP_PASS=dein-passwort
#
# Beispiel für eigenen SMTP-Server:
#   SMTP_HOST=mail.deinedomaene.de
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=biathlon@deinedomaene.de
#   SMTP_PASS=dein-passwort

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Biathlon Assistent <deine@gmail.com>"
